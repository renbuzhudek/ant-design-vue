</div><span class="ant-trigger-wrapper"><div class="ant-select ant-tree-select ant-select-single ant-select-show-search ant-select-show-arrow ant-select-allow-clear" style="width: 60%;"><div class="ant-select-selector"><!-- Multiple mode --><!-- Single mode --><span class="ant-select-selection-search"><input class="ant-select-selection-search-input" autocomplete="off" role="combobox" aria-expanded="false" aria-haspopup="tree" value=""></span><span class="ant-select-selection-item" title="my leaf">my leaf</span>
<!--v-if-->
