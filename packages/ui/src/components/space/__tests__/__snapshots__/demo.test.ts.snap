<!--teleport start-->
<transition-stub name="ant-slide-up" appear="false" persisted="false" css="true">
  <!--v-if-->
</transition-stub>
<!--teleport end--><button class="ant-btn ant-btn-solid ant-btn-md" type="button">
  <wave-stub disabled="false"></wave-stub>
  <!--v-if--><span class="ant-btn-content">Submit</span>
</button></div>
</div>"
`;

