exports[`Space demos > demo: Customize 1`] = `
"<div>
  <div class="ant-slider">
    <div class="ant-slider-rail"></div>
    <div class="ant-slider-track" style="left: 0%; width: 8%;"></div><!-- Steps/dots -->
    <!--v-if-->
    <!-- Marks -->
    <!--v-if-->
    <!-- Handle(s) -->
    <div class="ant-slider-handle" style="left: 8%;" role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="8" tabindex="0"></div>
  </div><br><br>
  <div class="ant-space ant-space-horizontal ant-space-align-center" style="column-gap: 8px; row-gap: 8px;"><button class="ant-btn ant-btn-solid ant-btn-md" type="button">
      <wave-stub disabled="false"></wave-stub>
